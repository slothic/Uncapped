<Window x:Class="Uncapped.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Saved login"
        Width="470" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        FontFamily="Segoe UI">

    <Border Margin="14" CornerRadius="12" Background="#171020" BorderThickness="1" BorderBrush="#2EFFFFFF">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="5" Direction="270" Opacity="0.65" Color="#000000" />
        </Border.Effect>

        <StackPanel Margin="26,22,26,22">

            <Grid>
                <TextBlock Text="Saved login" FontSize="17" Foreground="{StaticResource Ink}"
                           VerticalAlignment="Center" />
                <Button Style="{StaticResource ChromeButton}" Content="&#xE8BB;" HorizontalAlignment="Right"
                        Click="OnClose" />
            </Grid>

            <TextBlock Text="ACCOUNT" FontSize="10" FontWeight="SemiBold" Foreground="#8E8394"
                       Margin="0,20,0,6" />
            <Border CornerRadius="6" Background="#1EFFFFFF" Padding="10,7">
                <TextBox x:Name="AccountBox" Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource Ink}" FontSize="13" CaretBrush="{StaticResource Accent}" />
            </Border>

            <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold" Foreground="#8E8394"
                       Margin="0,16,0,6" />
            <Border CornerRadius="6" Background="#1EFFFFFF" Padding="10,7">
                <Grid>
                    <PasswordBox x:Name="PasswordBox" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource Ink}" FontSize="13"
                                 CaretBrush="{StaticResource Accent}" />
                    <TextBox x:Name="PasswordPlainBox" Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource Ink}" FontSize="13"
                             CaretBrush="{StaticResource Accent}" Visibility="Collapsed" />
                </Grid>
            </Border>

            <CheckBox x:Name="ShowPassword" Content="Show password" Foreground="#A79CAC" FontSize="11.5"
                      Margin="2,10,0,0" Checked="OnToggleReveal" Unchecked="OnToggleReveal" />

            <!-- Said plainly rather than buried: the person most affected should know. -->
            <Border CornerRadius="6" Background="#1FD26A4A" Padding="12,10" Margin="0,18,0,0">
                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#E4B7A6" LineHeight="17"
                           Text="This is saved in plain text on this computer. Anything that can read your files can read it. Please do not use a password you use anywhere else." />
            </Border>

            <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#9C91A2" Margin="2,14,0,0" LineHeight="17"
                       Text="When you press PLAY, the password is copied to your clipboard so you can paste it at the login screen with Ctrl+V. It is removed from the clipboard again after 45 seconds." />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button x:Name="ForgetButton" Style="{StaticResource QuietLink}" Content="Forget saved login"
                        VerticalAlignment="Center" Margin="0,0,20,0" Click="OnForget" />
                <Button Style="{StaticResource PlayButton}" Content="SAVE" Width="118" Height="40"
                        FontSize="13" Click="OnSave" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
