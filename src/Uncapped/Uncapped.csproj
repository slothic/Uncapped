<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <!-- WinForms is still referenced for FolderBrowserDialog, which WPF has no equivalent
         of. On .NET 5+ that dialog already renders as the modern Vista-style picker. -->
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Uncapped</RootNamespace>
    <AssemblyName>Uncapped</AssemblyName>
    <Version>1.2.2</Version>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <!-- Framework-dependent: ~2 MB instead of ~109 MB self-contained. The cost is that
         players need the .NET 9 Desktop Runtime installed. We cannot detect that ourselves -
         without the runtime our code never runs - but the .NET apphost shows its own dialog
         naming the missing runtime with a download link. Document it for players anyway. -->
    <SelfContained>false</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <!-- Trimming is unsupported for WPF/WinForms and breaks JSON reflection. Keep it off. -->
    <PublishTrimmed>false</PublishTrimmed>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- Extracted from the game client's RT_GROUP_ICON resource (all 4 sizes, 16-48px), so
         the launcher looks like the thing it launches. -->
    <ApplicationIcon>app.ico</ApplicationIcon>
    <AssemblyTitle>Uncapped Launcher</AssemblyTitle>
    <Product>Uncapped Launcher</Product>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MonoTorrent" Version="3.0.2" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\background.jpg" />
  </ItemGroup>

  <ItemGroup>
    <!-- The WPF implicit-usings set does not carry these, and the services rely on them. -->
    <Using Include="System.IO" />
    <Using Include="System.Net.Http" />
    <!-- Referencing WinForms for the folder picker makes Application and MessageBox
         ambiguous. Alias them to the WPF ones once, here, rather than in every file. -->
    <Using Include="System.Windows.Application" Alias="Application" />
    <Using Include="System.Windows.MessageBox" Alias="MessageBox" />
  </ItemGroup>

  <!--
    Bakes the crash-report webhook into the binary from a gitignored file, so the secret
    never lands in this public repo. Builds fine without the file - crash reporting is
    simply disabled unless the manifest supplies a webhook instead.
  -->
  <Target Name="GenerateBuildSecrets" BeforeTargets="BeforeCompile">
    <PropertyGroup>
      <WebhookFile>$(MSBuildProjectDirectory)\webhook.local.txt</WebhookFile>
      <WebhookValue></WebhookValue>
      <WebhookValue Condition="Exists('$(WebhookFile)')">$([System.IO.File]::ReadAllText('$(WebhookFile)').Trim())</WebhookValue>
      <GeneratedSecrets>$(IntermediateOutputPath)BuildSecrets.g.cs</GeneratedSecrets>
    </PropertyGroup>

    <ItemGroup>
      <SecretLine Include="// Generated at build time from webhook.local.txt. Do not edit or commit." />
      <SecretLine Include="namespace Uncapped%3B" />
      <SecretLine Include="internal static class BuildSecrets" />
      <SecretLine Include="{" />
      <SecretLine Include="    public const string CrashWebhook = &quot;$(WebhookValue)&quot;%3B" />
      <SecretLine Include="}" />
    </ItemGroup>

    <WriteLinesToFile File="$(GeneratedSecrets)" Lines="@(SecretLine)" Overwrite="true" WriteOnlyWhenDifferent="true" />

    <ItemGroup>
      <Compile Include="$(GeneratedSecrets)" />
      <FileWrites Include="$(GeneratedSecrets)" />
    </ItemGroup>

    <Message Importance="high" Text="Crash webhook: $([System.String]::Copy('$(WebhookValue)').Length) chars baked in" />
  </Target>

</Project>
