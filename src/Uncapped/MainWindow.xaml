<Window x:Class="Uncapped.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uncapped Launcher"
        Width="1160" Height="660"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="Segoe UI">

    <!-- Outer margin leaves room for the drop shadow to fall outside the window body. -->
    <Border Margin="14" CornerRadius="12" Background="#12080C">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="5" Direction="270" Opacity="0.62" Color="#000000" />
        </Border.Effect>

        <!-- Clips the artwork to the rounded corners. -->
        <Border CornerRadius="12" ClipToBounds="True">
            <Grid>

                <Image Source="Assets/background.jpg" Stretch="UniformToFill" />

                <!-- Drag anywhere on the art, since there is no title bar to grab. -->
                <Rectangle Fill="Transparent" MouseLeftButtonDown="OnDragWindow" />

                <!-- ── Window controls ─────────────────────────────────────────── -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,10,12,0">
                    <Button Style="{StaticResource ChromeButton}"
                            Content="&#xE921;" ToolTip="Minimise" Click="OnMinimize" />
                    <Button Style="{StaticResource ChromeButton}"
                            Content="&#xE8BB;" ToolTip="Close" Click="OnClose" />
                </StackPanel>

                <!-- ── News frame ──────────────────────────────────────────────────
                     Full height down the left. The right column deliberately keeps its
                     upper half empty: that is where a donate panel goes later, and leaving
                     the space now means adding it will not force another reshuffle. -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Stretch"
                        Margin="40,40,0,40" Width="600" CornerRadius="14"
                        BorderThickness="1" BorderBrush="#2EFFFFFF">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                            <GradientStop Offset="0" Color="#D41A1220" />
                            <GradientStop Offset="1" Color="#C8120B18" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="8" Direction="270" Opacity="0.5" Color="#000000" />
                    </Border.Effect>

                    <Grid Margin="22,18,20,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="NEWS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#8E8394" Margin="2,0,0,12" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="232" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Master: every entry, scrollable -->
                            <ListBox x:Name="NewsList" Grid.Column="0"
                                     Background="Transparent" BorderThickness="0"
                                     ItemContainerStyle="{StaticResource NewsItem}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     SelectionChanged="OnNewsSelected">
                                <ListBox.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBar}" />
                                </ListBox.Resources>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Date}" FontSize="10" Foreground="#7E7386" />
                                            <TextBlock Text="{Binding Title}" FontSize="12" Foreground="#DCD4DE"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Detail: the selected entry in full -->
                            <Border Grid.Column="1" Margin="18,0,0,0" Padding="18,2,0,0"
                                    BorderThickness="1,0,0,0" BorderBrush="#1FFFFFFF">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ScrollViewer.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBar}" />
                                    </ScrollViewer.Resources>
                                    <StackPanel>
                                        <TextBlock x:Name="DetailDate" FontSize="10.5" Foreground="#8E8394" />
                                        <TextBlock x:Name="DetailTitle" FontSize="16" Margin="0,4,0,0"
                                                   Foreground="{StaticResource Ink}" TextWrapping="Wrap" />
                                        <TextBlock x:Name="DetailBody" FontSize="12.5" Margin="0,10,0,0"
                                                   Foreground="#BDB2C0" TextWrapping="Wrap" LineHeight="19" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ── Wordmark, status and PLAY ───────────────────────────────── -->
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,44,44" Width="286">

                    <TextBlock Text="UNCAPPED" FontSize="42" FontWeight="Light"
                               HorizontalAlignment="Right" Foreground="{StaticResource Ink}"
                               Margin="0,0,0,18" IsHitTestVisible="False">
                        <!-- A soft glow keeps it legible wherever the sky behind is bright. -->
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.9" Color="#1A0A14" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" IsHitTestVisible="False">
                        <Ellipse x:Name="RealmDot" Width="7" Height="7" Fill="{StaticResource Muted}"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="RealmText" Text="Checking realm…" Margin="8,0,0,0"
                                   FontSize="11.5" Foreground="#D3C9D6" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.9" Color="#1A0A14" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock x:Name="StatusText" Text="Starting…" FontSize="11.5" Margin="0,9,0,0"
                               HorizontalAlignment="Right" TextAlignment="Right" Foreground="#BCB0BE"
                               TextTrimming="CharacterEllipsis" IsHitTestVisible="False">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.9" Color="#1A0A14" />
                        </TextBlock.Effect>
                    </TextBlock>

                    <ProgressBar x:Name="Progress" Style="{StaticResource SlimProgress}"
                                 Minimum="0" Maximum="1000" Value="0" Margin="0,10,0,0" />

                    <Button x:Name="PlayButton" Style="{StaticResource PlayButton}"
                            Content="PLAY" Height="66" Margin="0,16,0,0"
                            IsEnabled="False" Click="OnPlay" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button x:Name="RegisterLink" Style="{StaticResource QuietLink}"
                                Content="Create an account" Visibility="Collapsed" Click="OnRegister" />
                        <TextBlock x:Name="LinkSeparator" Text="  ·  " Foreground="#5A5060" FontSize="11"
                                   Visibility="Collapsed" />
                        <Button Style="{StaticResource QuietLink}"
                                Content="Change game folder" Click="OnChangeFolder" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
